# Backend environment variables
# Copy this to .env and fill in the values

# Shared secret — must match VITE_API_KEY in the frontend .env
API_KEY=test

# Scrape.do API token
SCRAPE_DO_TOKEN=your-scrape-do-token-here

# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_ORIGIN=http://localhost:5173

# Port the Hono server listens on (default: 3000)
PORT=3000
