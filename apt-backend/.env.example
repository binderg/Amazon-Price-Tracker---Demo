# Backend environment variables
# Copy this to .env and fill in the values

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared secret — must match VITE_API_KEY in the frontend .env
API_KEY=test

# ── Scraping ──────────────────────────────────────────────────────────────────
# Scrape.do API token (required). Get one free at https://scrape.do
SCRAPE_DO_TOKEN=your-scrape-do-token-here

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Global fallback check interval in minutes (each product can override this via UI)
CHECK_INTERVAL_MINUTES=60

# ── Price-drop notification thresholds (global defaults) ──────────────────────
# Per-product overrides are stored in the DB and configurable via the Settings UI.
#
# THRESHOLD_MODE: percent | absolute | both
#   percent  — trigger if (prev - curr) / prev >= DROP_THRESHOLD_PERCENT / 100
#   absolute — trigger if (prev - curr) >= DROP_THRESHOLD_ABSOLUTE
#   both     — trigger only if BOTH conditions are met simultaneously
THRESHOLD_MODE=percent
DROP_THRESHOLD_PERCENT=5
DROP_THRESHOLD_ABSOLUTE=0

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Hono server listens on (default: 3000)
PORT=3000

# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_ORIGIN=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info
